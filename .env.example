# ============================================
# Application Ports
# ============================================

# Port for the Hot-Reload Development server (dotnet-dev service - maps to 5000 inside)
APP_PORT=5000

# Port for the Angular Development server (frontend-dev service - maps to 4200 inside)
FRONTEND_PORT=4200

# Allowed CORS origins for the backend API (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080

# Port for the Native AOT Production server (dotnet-prod service - maps to 8080 inside)
PROD_APP_PORT=9090

# ============================================
# Database Configuration (MariaDB 11)
# ============================================
DB_ROOT_PASSWORD=root_secret
DB_NAME=dotnetsignin
DB_USER=dotnet_user
DB_PASSWORD=dotnet_secret

# ============================================
# Admin Tools
# ============================================

# Port for phpMyAdmin interface to manage the MariaDB database
PMA_PORT=8080
